---
import Base from "../layouts/Base.astro";
import Logo from "../components/Logo.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { site, projects, authorLinks, faqs, BUILD_DATE } from "../data/site";

const year = new Date().getFullYear();
const updated = new Date(BUILD_DATE).toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
});
const updatedISO = BUILD_DATE.slice(0, 10);
---

<Base>
  <header class="site-header">
    <div class="wrap site-header__inner">
      <Logo path="~" />
      <nav aria-label="Primary">
        <a class="navlink" href="https://jmrp.io" rel="me">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="9"></circle>
            <path d="M3.6 9h16.8M3.6 15h16.8M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18"></path>
          </svg>
          jmrp.io
        </a>
        <a class="navlink" href="https://github.com/jmrplens" rel="me noopener">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5A11.5 11.5 0 0 0 8.4 22.9c.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 5 18 5.3 18 5.3c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6A11.5 11.5 0 0 0 12 .5Z"></path>
          </svg>
          GitHub
        </a>
        <ThemeToggle />
      </nav>
    </div>
  </header>

  <main id="main">
    <!-- Hero -->
    <section class="hero">
      <div class="grid-bg" aria-hidden="true"></div>
      <div class="wrap hero__inner">
        <p class="kicker">documentation hub</p>
        <h1>Documentation for my open-source projects.</h1>
        <p class="hero__lead intro">
          I'm <strong>José M. Requena Plens</strong> (<span style="font-family:var(--ff-mono)">jmrplens</span>),
          an R&amp;D engineer building open-source developer and infrastructure tooling.
          This site indexes the technical documentation of my repositories, hosted on GitHub Pages.
          For everything else — writing, homelab, CV — my main website is <strong>jmrp.io</strong>.
        </p>
        <div class="hero__cta">
          <a class="btn btn--primary" href="https://jmrp.io" rel="me">
            Visit jmrp.io
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
          </a>
          <a class="btn btn--ghost" href="#projects">Browse documentation</a>
        </div>

        <aside class="banner">
          <span class="banner__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 8h.01M11 12h1v4h1"></path></svg>
          </span>
          <p>
            <strong>Looking for me, not a specific project?</strong>
            Head to <a href="https://jmrp.io">jmrp.io</a> — my primary website. This page exists only
            to point at each repository's documentation below.
          </p>
        </aside>
      </div>
    </section>

    <!-- Projects -->
    <section class="section" id="projects">
      <div class="wrap">
        <div class="section__head">
          <p class="kicker">projects</p>
          <h2>Documentation</h2>
        </div>
        <div class="grid">
          {projects.map((project) => <ProjectCard project={project} />)}
        </div>
      </div>
    </section>

    <!-- FAQ / citable answer units -->
    <section class="section section--faq" id="about">
      <div class="wrap">
        <div class="section__head">
          <p class="kicker">about</p>
          <h2>Frequently asked</h2>
        </div>
        <dl class="faq">
          {faqs.map((f) => (
            <div class="faq__item">
              <dt>{f.q}</dt>
              <dd set:html={f.a.replace(/jmrp\.io/g, '<a href="https://jmrp.io">jmrp.io</a>')} />
            </div>
          ))}
        </dl>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="wrap site-footer__inner">
      <nav class="site-footer__links" aria-label="Elsewhere">
        {authorLinks.map((l) => <a href={l.href} rel="me noopener">{l.label}</a>)}
      </nav>
      <p class="site-footer__meta">
        © {year} {site.author.name} · <time datetime={updatedISO}>Updated {updated}</time> · built with Astro
      </p>
    </div>
  </footer>
</Base>
