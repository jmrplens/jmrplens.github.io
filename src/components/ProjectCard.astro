---
import type { Project } from "../data/site";
interface Props {
  project: Project;
}
const { project } = Astro.props;
---

<article class="card">
  <p class="card__kicker">{project.kicker}</p>
  <h3><a href={project.docsUrl}>{project.name}</a></h3>
  <p class="card__desc">{project.description}</p>

  <div class="card__meta">
    <span class="pill pill--status"><span class="dot" aria-hidden="true"></span>{project.status}</span>
    <span class="pill">{project.language}</span>
  </div>

  <div class="card__foot">
    <a class="card__link" href={project.docsUrl}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2Z"></path>
      </svg>
      Documentation
    </a>
    <a class="card__link" href={project.repoUrl} rel="noopener">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 .5A11.5 11.5 0 0 0 8.4 22.9c.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 5 18 5.3 18 5.3c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6A11.5 11.5 0 0 0 12 .5Z"></path>
      </svg>
      GitHub
    </a>
  </div>
</article>
