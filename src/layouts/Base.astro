---
// Self-hosted fonts (no CDN → CSP-friendly, matches the design handoff).
import "@fontsource/space-grotesk/500.css";
import "@fontsource/space-grotesk/700.css";
import "@fontsource/ibm-plex-sans/400.css";
import "@fontsource/ibm-plex-sans/500.css";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import "@fontsource/ibm-plex-mono/600.css";
import "../styles/global.css";

import { site, projects } from "../data/site";

const canonical = new URL(Astro.url.pathname, site.origin).href;
const ogImage = new URL("og.png", site.origin).href;

// GEO: a single @graph tying the hub to the author's primary identity (jmrp.io)
// and to each documented project as a SoftwareSourceCode entry in an ItemList.
const PERSON_ID = "https://jmrp.io/#person";
const WEBSITE_ID = `${site.origin}/#website`;
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": PERSON_ID,
      name: site.author.name,
      alternateName: site.author.alternateName,
      url: site.author.mainSite,
      image: site.author.image,
      sameAs: [...site.author.sameAs],
    },
    {
      "@type": "WebSite",
      "@id": WEBSITE_ID,
      url: `${site.origin}/`,
      name: site.title,
      description: site.description,
      inLanguage: "en",
      publisher: { "@id": PERSON_ID },
      about: { "@id": PERSON_ID },
    },
    {
      "@type": "ProfilePage",
      "@id": `${site.origin}/#webpage`,
      url: `${site.origin}/`,
      name: site.title,
      description: site.description,
      isPartOf: { "@id": WEBSITE_ID },
      about: { "@id": PERSON_ID },
      mainEntity: { "@id": PERSON_ID },
      primaryImageOfPage: ogImage,
      inLanguage: "en",
      // The author's primary website is the canonical destination.
      significantLink: [site.author.mainSite, ...projects.map((p) => p.docsUrl)],
    },
    {
      "@type": "ItemList",
      "@id": `${site.origin}/#projects`,
      name: "Documented projects",
      numberOfItems: projects.length,
      itemListElement: projects.map((p, i) => ({
        "@type": "ListItem",
        position: i + 1,
        url: p.docsUrl,
        item: {
          "@type": "SoftwareSourceCode",
          name: p.name,
          description: p.description,
          url: p.docsUrl,
          codeRepository: p.repoUrl,
          programmingLanguage: p.language,
          author: { "@id": PERSON_ID },
        },
      })),
    },
  ],
};
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{site.title}</title>
    <meta name="description" content={site.description} />
    <link rel="canonical" href={canonical} />
    <meta name="author" content={site.author.name} />
    <meta name="generator" content={Astro.generator} />

    <!-- Theme colour swaps with the active theme (see inline script + toggle). -->
    <meta name="theme-color" content="#0A0A0B" />
    <meta name="color-scheme" content="dark light" />

    <!-- Bing Webmaster Tools verification for the host root. -->
    <meta name="msvalidate.01" content={site.bingVerify} />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="profile" />
    <meta property="og:site_name" content="jmrplens" />
    <meta property="og:title" content={site.title} />
    <meta property="og:description" content={site.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={site.title} />
    <meta name="twitter:description" content={site.description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap.xml" />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="llms.txt" />

    <!-- Apply persisted / preferred theme before paint (no flash). -->
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem("theme");
          const prefersLight = matchMedia("(prefers-color-scheme: light)").matches;
          const theme = stored ?? (prefersLight ? "light" : "dark");
          document.documentElement.dataset.theme = theme;
          const meta = document.querySelector('meta[name="theme-color"]');
          if (meta) meta.setAttribute("content", theme === "light" ? "#FAFAF7" : "#0A0A0B");
        } catch (e) {
          /* default dark */
        }
      })();
    </script>

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />
  </body>
</html>
